# The Matrix - Oracle .gitignore
# Never commit sensitive configuration to version control!

# Environment files with secrets
.env
.env.local
.env.production
.env.*.local

# Keep the example file
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
matrix_env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Database files (if using SQLite locally)
*.db
*.sqlite
*.sqlite3
